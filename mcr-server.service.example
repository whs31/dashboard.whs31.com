[Unit]
Description=MMS Crash Report Server
After=network.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/opt/mcr-server
Environment="BIND_ADDRESS=0.0.0.0:3000"
Environment="RUST_LOG=info,tower_http=debug"
ExecStart=/opt/mcr-server/mcr_server
Restart=on-failure
RestartSec=5s

# Security hardening
NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=strict
ProtectHome=true
ReadWritePaths=/opt/mcr-server/crash_reports

[Install]
WantedBy=multi-user.target
